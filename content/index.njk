---
title: Home
layout: layouts/home.njk
thumbnail: assets/images/thumb-crayons.png
js: /assets/js/copy-snippits.js
---
<div class="filters">
<div class="sort-group">
	<label style="font-weight: bold; margin-inline-end: .6em" for="sort-options">Sort:</label>
	<select class="sort" id="sort-options">
	  <option value="default" selected>Default (alphabetical)</option>
	  <option value="color">Color (Hex Code)</option>
	  <option value="brightness">Brightness</option>
	  <option value="hue">Hue</option>
	  <option value="saturation">Saturation</option>
	</select>
  </div>

  <div class="filter-group">
	<p class="visually-hidden">Filter by Palette:</p>
	<label>
	  <input type="radio" name="palette-filter" value="all" checked>
	  All
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette1">
	  🌌 Celestial Haze
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette2">
	  🚀 Future vision
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette3">
	  🌸 Sugar Rush
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette4">
	  🌿 Soft botanicals
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette5">
	  🌺 Retro pop
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette6">
	  ☕️ Mid-Mod Mood
	</label>
	<label>
	  <input type="radio" name="palette-filter" value="palette7">
	  🕯️ Eldritch Archives
	</label>
  </div>
</div>

{% include "partials/crayon-sprite.njk" -%}
<ol class="crayons" id="crayon-list">
{% for crayon in crayola -%}
<li id="crayon-{{ crayon.hex | slugify }}">
  <figure>
    <svg class="crayon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1172 121" role="img" aria-label="{{ crayon.color }} crayon">
      <path fill="{{ crayon.hex | crayonWrapper }}" d="M186 0h922v121H186z"/>
      <use href="#crayon-base"/>
      <path fill="{{ crayon.hex }}" d="M1108 1h60a4 4 0 0 1 4 4v114a4 4 0 0 1-4 4h-60V1ZM186 0h-59.5a4 4 0 0 0-4 4v13.16a4 4 0 0 1-3.384 3.951L3.384 39.136A4 4 0 0 0 0 43.089v31.89a4 4 0 0 0 3.29 3.936l115.92 20.904a4 4 0 0 1 3.29 3.937V118a4 4 0 0 0 4 4H186V0Z"/>
    </svg>
    <span class="crayon-label">{{ crayon.color }}</span>
  </figure>
  <button class="copy-btn" data-snippet-id="snippet-{{ crayon.hex }}">
	<code id="snippet-{{ crayon.hex }}">{{ crayon.hex }}</code>
  </button>
</li>
{% endfor %}
</ol>
