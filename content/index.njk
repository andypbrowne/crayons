---
title: Home
layout: layouts/home.njk
thumbnail: assets/images/thumb-crayons.png
js: /assets/js/main.js
---
<div class="filters">
  <input type="checkbox" id="filters-panel" class="filters-panel-toggle">
  <label for="filters-panel" class="filters-toggle">
    <svg class="filters-toggle-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6 9h12M8 12h8M10 15h4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <span>Filters</span>
  </label>
  <div class="filters-body">
    <div class="sort-group">
      <label style="font-weight: bold; margin-inline-end: .6em" for="sort-options">Sort:</label>
      <select class="sort" id="sort-options">
        <option value="default" selected>Default (alphabetical)</option>
        <option value="color">Color (Hex Code)</option>
        <option value="brightness">Brightness</option>
        <option value="hue">Hue</option>
        <option value="saturation">Saturation</option>
      </select>
    </div>

    <div id="palette-tools" class="palette-tools"></div>

    <div class="filter-group" id="palette-filter-group" aria-live="polite"></div>
  </div>
</div>

{% include "partials/crayon-sprite.njk" -%}
<p id="crayon-list-empty" class="crayon-list-empty" hidden>No crayons match this palette yet. Add colors from the row menu.</p>
<ol class="crayons" id="crayon-list">
{% for crayon in crayola -%}
{% set hexSlug = crayon.hex | slugify -%}
<li id="crayon-{{ hexSlug }}" style="--crayon-color: {{ crayon.hex }}" data-hex="{{ crayon.hex }}" data-color-name="{{ crayon.color }}">
  <figure>
    <svg class="crayon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1172 121" role="img" aria-label="{{ crayon.color }} crayon">
      <path class="crayon-wrapper" fill="var(--crayon-wrapper)" d="M186 0h922v121H186z"/>
      <use href="#crayon-base"/>
      <path class="crayon-tip" fill="var(--crayon-color)" d="M1108 1h60a4 4 0 0 1 4 4v114a4 4 0 0 1-4 4h-60V1ZM186 0h-59.5a4 4 0 0 0-4 4v13.16a4 4 0 0 1-3.384 3.951L3.384 39.136A4 4 0 0 0 0 43.089v31.89a4 4 0 0 0 3.29 3.936l115.92 20.904a4 4 0 0 1 3.29 3.937V118a4 4 0 0 0 4 4H186V0Z"/>
    </svg>
    <span class="crayon-label">{{ crayon.color }}</span>
  </figure>
  <button
    type="button"
    class="row-actions-btn"
    popovertarget="actions-{{ hexSlug }}"
    aria-label="More actions for {{ crayon.color }}"
    aria-haspopup="menu"
  >⋯</button>
  <div
    class="row-actions-menu"
    popover="auto"
    id="actions-{{ hexSlug }}"
    role="menu"
    data-hex="{{ crayon.hex }}"
    data-color-name="{{ crayon.color }}"
  >
    <button type="button" class="row-actions-item" data-action="copy-hex" role="menuitem">Copy hex code</button>
    <button type="button" class="row-actions-item" data-action="copy-name" role="menuitem">Copy color name</button>
    <div class="row-actions-submenu-label">Add to palette</div>
    <div class="row-actions-submenu" role="group" aria-label="Add to palette"></div>
  </div>
</li>
{% endfor %}
</ol>
