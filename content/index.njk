---
title: Crayons
layout: layouts/home.njk
thumbnail: assets/images/thumb-crayons.png
js: /assets/js/main.js
shareMeta: true
---
{% macro copyIcon() -%}
<svg class="row-actions-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="4.5" y="4.5" width="7" height="8" rx="1" stroke="currentColor" stroke-width="1.25"/><path d="M3.5 9.5h-1a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
{%- endmacro %}
<div class="filters">
  <input type="checkbox" id="filters-panel" class="filters-panel-toggle">
  <div class="filters-toggle-bar">
    <label for="filters-panel" class="filters-toggle">
      <span class="filters-toggle-icon kebab-btn" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
          <circle cx="6" cy="7" r="2" fill="currentColor"/>
          <circle cx="14" cy="7" r="2" fill="currentColor"/>
          <circle cx="10" cy="13" r="2" fill="currentColor"/>
        </svg>
      </span>
      <span>Filters</span>
    </label>
    <label for="filters-panel" class="filter-panel-close" aria-label="Close filters">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M5 5l10 10M15 5 5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </label>
  </div>

  <aside class="filter-panel" id="filter-panel" aria-label="Filters">
    <div class="filter-panel-top-bar panel-chrome">
      <button type="button" class="panel-drag-handle" aria-label="Drag panel">
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="20" viewBox="0 0 12 20" fill="none" aria-hidden="true">
          <circle cx="3" cy="4" r="1.5" fill="currentColor"/>
          <circle cx="9" cy="4" r="1.5" fill="currentColor"/>
          <circle cx="3" cy="10" r="1.5" fill="currentColor"/>
          <circle cx="9" cy="10" r="1.5" fill="currentColor"/>
          <circle cx="3" cy="16" r="1.5" fill="currentColor"/>
          <circle cx="9" cy="16" r="1.5" fill="currentColor"/>
        </svg>
      </button>
      <span class="panel-title">Filters</span>
      <button type="button" class="panel-collapse-btn" aria-expanded="true" aria-label="Collapse panel">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="filter-panel-content">
      <div class="sort-group">
        <label class="sort-group-label" for="sort-options">Sort</label>
        <div class="sort-select-wrap">
          <select class="sort" id="sort-options">
            <option value="default" selected>Default (alphabetical)</option>
            <option value="color">Color (Hex Code)</option>
            <option value="brightness">Brightness</option>
            <option value="hue">Hue</option>
            <option value="saturation">Saturation</option>
          </select>
          <svg class="sort-select-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <section class="starter-palettes-section" aria-labelledby="starter-palettes-heading">
        <h2 class="filter-section-title" id="starter-palettes-heading">Starter Palettes</h2>
        <div class="starter-palettes-zone">
          <div class="starter-palettes-zone-header">
            <span class="starter-palettes-zone-title">Starter Palettes</span>
            <button type="button" id="starter-palettes-toggle" class="starter-palettes-toggle" aria-expanded="true">Show less</button>
          </div>
          <div id="palette-filter-group" class="starter-palettes-list" role="radiogroup" aria-label="Starter palettes"></div>
        </div>
      </section>

      <hr class="filter-panel-divider">

      <section class="your-palettes-section" aria-labelledby="your-palettes-heading">
        <h2 class="filter-section-title" id="your-palettes-heading">Your Palettes</h2>
        <div id="palette-tools" class="your-palettes-list"></div>
        <button type="button" id="new-palette-btn" class="new-palette-btn">+ New palette</button>
      </section>

      <div class="filter-panel-footer">
        <button type="button" id="filter-clear-btn" class="filter-panel-link">Clear filters</button>
        <button type="button" id="filter-copy-link-btn" class="filter-panel-link">Copy link</button>
      </div>

      <button type="button" id="save-shared-btn" class="save-shared-btn" hidden>Save as palette</button>
    </div>
  </aside>
</div>

{% include "partials/crayon-sprite.njk" -%}
<p id="crayon-list-empty" class="crayon-list-empty" hidden>No crayons match this palette yet. Add colors from the row menu.</p>
<ol class="crayons" id="crayon-list">
{% for crayon in crayola -%}
{% set hexSlug = crayon.hex | slugify -%}
<li id="crayon-{{ hexSlug }}" style="--crayon-color: {{ crayon.hex }}" data-hex="{{ crayon.hex }}" data-color-name="{{ crayon.color }}">
  <figure>
    <svg class="crayon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1172 121" role="img" aria-label="{{ crayon.color }} crayon">
      <path class="crayon-wrapper" fill="var(--crayon-wrapper)" d="M186 0h922v121H186z"/>
      <use href="#crayon-base"/>
      <path class="crayon-tip" fill="var(--crayon-color)" d="M1108 1h60a4 4 0 0 1 4 4v114a4 4 0 0 1-4 4h-60V1ZM186 0h-59.5a4 4 0 0 0-4 4v13.16a4 4 0 0 1-3.384 3.951L3.384 39.136A4 4 0 0 0 0 43.089v31.89a4 4 0 0 0 3.29 3.936l115.92 20.904a4 4 0 0 1 3.29 3.937V118a4 4 0 0 0 4 4H186V0Z"/>
    </svg>
    <span class="crayon-label">{{ crayon.color }}</span>
  </figure>
  <button
    type="button"
    class="row-actions-btn kebab-btn"
    popovertarget="actions-{{ hexSlug }}"
    aria-label="More actions for {{ crayon.color }}"
    aria-haspopup="menu"
  ><svg xmlns="http://www.w3.org/2000/svg" width="4" height="18" viewBox="0 0 4 18" aria-hidden="true"><circle cx="2" cy="2" r="2" fill="currentColor"/><circle cx="2" cy="9" r="2" fill="currentColor"/><circle cx="2" cy="16" r="2" fill="currentColor"/></svg></button>
  <div
    class="row-actions-menu"
    popover="auto"
    id="actions-{{ hexSlug }}"
    role="menu"
    data-hex="{{ crayon.hex }}"
    data-color-name="{{ crayon.color }}"
  >
    <div class="row-actions-header" role="presentation" aria-hidden="true">
      <span class="row-actions-swatch" style="background-color: {{ crayon.hex }}"></span>
      <div class="row-actions-header-meta">
        <span class="row-actions-color-name">{{ crayon.color }}</span>
        <span class="row-actions-hex">{{ crayon.hex }}</span>
      </div>
    </div>
    <button type="button" class="row-actions-item" data-action="copy-hex" role="menuitem">{{ copyIcon() }}Copy hex code</button>
    <button type="button" class="row-actions-item" data-action="copy-name" role="menuitem">{{ copyIcon() }}Copy color name</button>
    <div class="row-actions-submenu-label">Manage palette</div>
    <div class="row-actions-submenu" role="group" aria-label="Manage palette"></div>
  </div>
</li>
{% endfor %}
</ol>
